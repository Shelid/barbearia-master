# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Admin SDK credentials for secure server-side actions.
# Use a service account with least privilege and escape line breaks in the private key as \n.
FIREBASE_ADMIN_PROJECT_ID="my-firebase-project"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk@example.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----\n"

# Firebase App Check for public abuse protection.
# Add your reCAPTCHA v3 site key here to send App Check tokens from the browser.
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY="your_recaptcha_v3_site_key"

# Set to true only after App Check is configured in Firebase and the site key above is active.
FIREBASE_APP_CHECK_ENFORCE="false"

# Optional: consume App Check tokens to reject replay attacks on sensitive public endpoints.
FIREBASE_APP_CHECK_CONSUME="false"

# Public waitlist API hardening.
# Use a long random secret in production so rate-limit fingerprints cannot be predicted.
WAITLIST_RATE_LIMIT_SECRET="change-this-to-a-long-random-secret"
WAITLIST_RATE_LIMIT_MAX="3"
WAITLIST_RATE_LIMIT_WINDOW_SECONDS="600"

# Optional comma-separated allowlist of extra origins allowed to call the public waitlist API.
WAITLIST_ALLOWED_ORIGINS="https://www.seudominio.es,https://app.seudominio.es"
